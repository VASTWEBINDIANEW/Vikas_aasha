@using Vastwebmulti.Models
@model IEnumerable<Vastwebmulti.Models.User_number_status>
 @{
        VastwebmultiEntities db = new VastwebmultiEntities();
        ViewBag.Title = "webappsetting";
        Layout = "~/Areas/ADMIN/Views/Shared/_Layout.cshtml";
    }
<section class="content">
    <div>
        @{
            var chkd = db.Retailer_Details.ToList();
        }
        @using (Html.BeginForm())
        {
            <select name="ids">
                <option value="">ALL</option>
                @foreach (var i in chkd)
                {
                    <option value="@i.RetailerId">@i.Frm_Name</option>
                }
            </select>
            <input type="submit" value="submit" />
        }
    </div>
    <table class="table">
        <tr>
            <th>USER</th>
            <th>Number Status</th>


        </tr>
        @{
            var k = 0;
        }
        @foreach (var i in Model)
        {
            <tr>
                <td>
                    @{
                        var chk = db.Retailer_Details.Where(s => s.RetailerId == i.Userid).SingleOrDefault();

                    }
                    @chk.Frm_Name
                </td>
                <td class="websss">
                    @if (i.NumberStatus == true)
                    {
                        <button data-toggle="modal" data-target="#exampleModal" style=" padding: 1px 16px; background-color:green;color:white" onclick="changesetting('@i.Userid',@k,false)">ON</button>
                    }
                    else
                    {
                        <button data-toggle="modal" data-target="#exampleModal" style=" padding: 1px 15px; background-color:red;color:white" onclick="changesetting('@i.Userid',@k,true)">OFF</button>
                    }

                </td>

            </tr>
            k++;
        }

    </table>

    <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Enter OTP</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="number" id="tops" placeholder="Enter OTP" />

                </div>
                <div style="color:red" id="tstsmessage">
                    Otp Sent Successfully..........!
                </div>
                <div class="modal-footer" id="chkdss">

                </div>
            </div>
        </div>
    </div>
</section>

<script>
function changesetting(id, no, sts) {
     $.ajax({
            url: "@Url.Action("otpsentforsts11", "Home")",
         success: function (data) {

            }
        });
        document.getElementById('chkdss').innerHTML = "";
        document.getElementById('chkdss').innerHTML = '<button onclick="changesetting11(\'' + id + '\', ' + no + ','+ sts+')" type="button" id="savebutton" class="btn btn-primary">Save changes</button>'



        }
    function changesetting11(id, no, sts) {
        var chjs = document.getElementById('tops').value;

        if (chjs.length == 4) {
            $.ajax({
                url: "@Url.Action("usernumbersts", "Home")",
                data: { userid: id, sts: sts, otp: chjs },
                success: function (data) {
                    if (data.status1 == true) {
                        if (data.status == true) {
                            document.getElementsByClassName('websss')[no].innerHTML = '<button data-toggle="modal" data-target="#exampleModal" style="padding: 1px 15px; background-color:green; color:white" onclick="changesetting(\'' + id + '\', ' + no + ', false)">ON</button>';
                        } else {
                            document.getElementsByClassName('websss')[no].innerHTML = '<button data-toggle="modal" data-target="#exampleModal" style="padding: 1px 15px; background-color:red; color:white" onclick="changesetting(\'' + id + '\', ' + no + ', true)">OFF</button>';
                        }
                        $('#exampleModal').modal('hide');
                    }
                    else {
                        document.getElementById('tstsmessage').innerHTML = 'OTP Not Matched....!'
                    }
                }
            });
        }
        else {
            document.getElementById('tstsmessage').innerHTML = 'otp is in 4 digit'
        }


}

</script>


