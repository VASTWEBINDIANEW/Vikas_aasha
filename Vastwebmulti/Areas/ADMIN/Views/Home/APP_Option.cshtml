<script>
    function checksave(img, c, t, l, d) {
        console.log(d);
        var s=0;
        var check = document.getElementsByClassName('checkboxdata');

            if (check[d].checked == true) {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("sliderimagessave", "Home")',
                    data: { img: img, cat: c, type: t, Lang: l },
                    success: function (result) {
                        if (result != "saved") {
                            check[d].checked = false;
                        }
                        alert(result);
                    }
                });
            }
            else {
                 $.ajax({
                    type: "POST",
                    url: '@Url.Action("sliderimagesdelete", "Home")',
                    data: { img: img, cat: c, type: t, Lang: l },
                    success: function (result) {
                        alert(result);
                    }
                });
            }

    }
</script>
