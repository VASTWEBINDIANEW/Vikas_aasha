                            <div class="table-container">
                                <table id="faqlist"></table>
                            </div>

                            <script>
                                $.ajax({
                                    type: "POST",
                                    url: '@Url.Action("faqsave", "Home")',
                                    data: { q :null , a : null },
                                    success: function (result) {
                                        var faq = document.getElementById('faqlist');
                                        faq.innerHTML = "";
                                        for (var i = 0; i < result.length; i++) {
                                            var br = document.createElement('tr');
                                            var bU = document.createElement('button');
                                            bU.textContent = "-";
                                            bU.setAttribute('onclick', 'deletefaq(' + result[i].idno + ',' + i + ')')
                                            bU.setAttribute('style', 'padding: 0px 20px; background: red;color: white;font-size: larger;');
                                            bU.setAttribute('class', 'deletefsw');
                                            br.setAttribute('style', 'font-size: large;');
                                            var br1 = document.createElement('tr');
                                            var br2 = document.createElement('tr');
                                            var hr = document.createElement('hr');
                                            br1.setAttribute('style', 'font-size: large;');
                                            br.appendChild(document.createTextNode('Q.' + (i + 1) + ' ' + result[i].question));
                                            br2.appendChild(bU);
                                            br1.appendChild(document.createTextNode('Ans.' + result[i].answer));
                                            faq.appendChild(br);
                                            faq.appendChild(br1);
                                            faq.appendChild(br2);
                                            faq.appendChild(hr);
                                        }


                                    }
                                });
                                function isEmptyOrSpaces(str) {
                                    return str === null || str.match(/^ *$/) !== null;
                                }
                                function faqsave() {
                                    var ques = document.getElementById('faqq').value;
                                    var ans = document.getElementById('faqa').value;

if (!isEmptyOrSpaces(ques) && !isEmptyOrSpaces(ans)) {
    $.ajax({
        type: "POST",
        url: '@Url.Action("faqsave", "Home")',
        data: { q: ques, a: ans },
        success: function (result) {
            var faq = document.getElementById('faqlist');
            faq.innerHTML = "";
            for (var i = 0; i < result.length; i++) {
                var br = document.createElement('tr');
                var bU = document.createElement('button');
                bU.textContent = "-";
                bU.setAttribute('onclick', 'deletefaq(' + result[i].idno +','+i+ ')')
                bU.setAttribute('style', 'padding: 0px 20px; background: red;color: white;font-size: larger;');
                bU.setAttribute('class', 'deletefsw');
                br.setAttribute('style', 'font-size: large;');
                var br1 = document.createElement('tr');
                var br2 = document.createElement('tr');
                var hr = document.createElement('hr');
                br1.setAttribute('style', 'font-size: large;');
                br.appendChild(document.createTextNode('Q.' + (i + 1) + ' ' + result[i].question));
                br2.appendChild(bU);
                br1.appendChild(document.createTextNode('Ans.' + result[i].answer));
                faq.appendChild(br);
                faq.appendChild(br1);
                faq.appendChild(br2);
                faq.appendChild(hr);


            }
            alert('FAQ Saved');
            document.getElementById('faqq').value = "";
            document.getElementById('faqa').value = "";
        }
    });
}

                                    else {
                                        alert('Empty text not allowed');
                                    }
                                }

                                function deletefaq(d) {
                                    if (d != null) {
                                        $.ajax({
                                            type: "POST",
                                            url: '@Url.Action("faqdelete", "Home")',
                                            data: { id: d },
                                            success: function (result) {
                                                var faq = document.getElementById('faqlist');
                                                faq.innerHTML = "";
                                                for (var i = 0; i < result.length; i++) {
                                                    var br = document.createElement('tr');
                                                    var bU = document.createElement('button');
                                                    bU.textContent = "-";
                                                    bU.setAttribute('onclick', 'deletefaq(' + result[i].idno + ',' + i + ')')
                                                    bU.setAttribute('style', 'padding: 0px 20px; background: red;color: white;font-size: larger;');
                                                    bU.setAttribute('class', 'deletefsw');
                                                    br.setAttribute('style', 'font-size: large;');
                                                    var br1 = document.createElement('tr');
                                                    var br2 = document.createElement('tr');
                                                    var hr = document.createElement('hr');
                                                    br1.setAttribute('style', 'font-size: large;');
                                                    br.appendChild(document.createTextNode('Q.' + (i + 1) + ' ' + result[i].question));
                                                    br2.appendChild(bU);
                                                    br1.appendChild(document.createTextNode('Ans.' + result[i].answer));
                                                    faq.appendChild(br);
                                                    faq.appendChild(br1);
                                                    faq.appendChild(br2);
                                                    faq.appendChild(hr);


                                                }
                                                alert('FAQ Deleted');

                                            }
                                        });

                                    }
                                    else {
                                        alert('Faq not Deleted');
                                    }
                                }
                            </script>
