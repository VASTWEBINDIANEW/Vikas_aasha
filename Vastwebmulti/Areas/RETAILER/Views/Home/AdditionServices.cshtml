@model IEnumerable<Vastwebmulti.Models.SERVICECOLUMN>
@{
    ViewBag.Title = "AdditionServices";
}
<style>
    #head {
        background: #00baf2;
        padding: 1px 14px;
        color: #fff;
        font-size: 24px;
        text-transform: uppercase;
        text-align:center;
    }
  select.yes1,input.yes1 {
        margin: 10px;
        width: -moz-available;
        height: 34px;
        border: 1px solid #ccc;
        padding: 0px 7px;
    }
    .page-header-third {
        margin: auto;
        height: auto;
        display: flow-root;
        margin-bottom: 11px;
        background: rgb(255 255 255 / 95%);
        padding: 5px;
        box-shadow: 0px 0px 5px -2px;
        border-radius: 4px;
        width: fit-content;
        margin-top: 20px;
    }
    .Submit22 button {
        background: #00baf2;
        padding: 2px 21px;
        font-size: 20px;
        border: 1px solid #fff;
        color: #fff;
        border-radius: 4px;
        margin: 11px;
    }
    .Submit22 {
        text-align: end;
    }
    label {
        text-transform: capitalize;
    }
</style>
<div style="margin: 98px 16px 11px 220px;">
    
    <div class="page-header-third"  style="width:100%;" ><div id="head">@Session["Servics"]</div></div>
    <div class="page-header-third">
        @foreach (var i in Model)
        {
            if (i.isdeleted == true)
            {
                <input type="hidden" value="@i.header" class="yes" />

                <div style="width:70%;float:right;"><input type="hidden" value="" class="yes1" /></div><br>
            }
            else
            {
                <input type="hidden" value="@i.header" class="yes" />
                <div style="width:30%;float:left;">
                    <label style="margin: 10px; width: -moz-available; height: 34px;">@i.header</label>
                </div>
                if (i.TYPE.Contains("Dropdown"))
                {
                    var spt = Convert.ToChar("?");
                    var opt = i.TYPE.Split(spt);

                    <div style="width:70%;float:right;">
                        @*<input type="@i.TYPE" placeholder="Enter Your @i.header" class="yes1" /><br>*@
                        <select class="yes1" >
                            @foreach (var m in opt)
                            {
                                if (!string.IsNullOrEmpty(m) && m != "Dropdown")
                                {
                            <option>@m</option>
                                }
                            }
                        </select>
                    </div>

                }
                else
                {
                    <div style="width:70%;float:right;">
                        <input type="@i.TYPE" placeholder="Enter Your @i.header" class="yes1" /><br>
                    </div>
                }


            }
        }
        <div class="Submit22"><button onclick="cliss()">Submit</button></div>

    </div>
    <script>
        function cliss() {
            var sesdf = document.getElementById('head').innerHTML;
            var sesdf1 = sesdf.trimLeft();
            var sesdf2 = sesdf.trimRight();
            var element = document.getElementsByClassName('yes');
            var element1 = document.getElementsByClassName('yes1');
            var save = '';
            var send = '';
            for (var i = 0; i < element.length; i++) {
                var save1 = element[i].value;
                var save2 = element1[i].value;


                save = save + save1 + 'स' + save2 + 'स';

            }
          

                $.ajax({
                    url: '@Url.Action("SAVESERVIESDS")',
                    data: { set: save , sess: sesdf2 },
                type: "GET",
                cache: false,
                    success: function (data) {
                        alert(data);
                    location.reload();
                }
       })











        }

    </script>
</div>

