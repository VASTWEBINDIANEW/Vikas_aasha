<!--Continue button validation and Show Sender Remitter Details -->
<script>
 function btnconctinue(mb) {
        //$('#tableshow').empty();

var mobile = "";
if (mb == "")
{
mobile = $("#mobile").val();
}
else {
mobile = mb;
}

if (mobile == "") {

document.getElementById("mobile1").innerHTML = "Enter remitter mobile number";
document.getElementById("mobile2").innerHTML = "Enter remitter mobile number";
event.preventDefault();
}
else if (mobile != "") {
//var mobile1 = document.getElementById("mobile").value.length;
var mobile1 = document.getElementById("mobile").value.length;
if (mobile1 != 10) {
document.getElementById("mobile1").innerHTML = "Number should be [10] digits";
document.getElementById("mobile2").innerHTML = "Number should be [10] digits";
event.preventDefault();
}
else {
    $.ajax({
        type: 'Post',
        url: "@Url.Action("process_sender_cyber", "Home")",
        data: { sender_number: mobile },
        dataType: 'json',
        cache: false,
        async: true,

        success: function (data) {
            //$('#table').empty();
            var sts = "";
            try {
                sts = data.statuscode;

            }
            catch (e) { }

            if (data.status == "failure") {
                swal("Error!", data.message, "error");
            }

            else if (sts == "RNF" || data.status == "register") {
                $("#myModal").modal('show');
                event.preventDefault();
            }
            else if (sts == "TXN") {
                var isverified = data.data.remitter.is_verified;
                 if (isverified == 0) {
                    $('#remiterid').val(data.data.remitter.id);
                    $('#remitermobileno').val(mobile);
                    $("#RegistervalidateOTPModal").modal('show');
                    event.preventDefault();
                }
                if (isverified == 1) {
