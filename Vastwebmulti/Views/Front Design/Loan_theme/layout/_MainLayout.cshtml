    <script>
        $(document).ready(function () {
            // Set the animation interval in milliseconds
            var slideInterval = 3000; // 3 seconds

            // Function to slide the client logos
            function slideLogos() {
                var $slider = $('#clientSlider');
                var $firstLogo = $slider.find('.col-8:first');

                // Animate the first logo to the left and hide it
                $firstLogo.animate({ marginLeft: '-200px', opacity: 0 }, 1000, function () {
                    // Move the first logo to the end of the slider
                    $firstLogo.appendTo($slider).removeAttr('style');
                });
            }

            // Call the slideLogos function at the specified interval
            setInterval(slideLogos, slideInterval);
        });
    </script>

