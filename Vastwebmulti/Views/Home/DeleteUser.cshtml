@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<div class="container mt-5">
    <h3 class="text-center">Verify and Delete Account</h3>
    <div class="card p-4 shadow-sm">
        <div class="mb-3">
            <label for="userInput" class="form-label">Email ID or Mobile No.</label>
            <input type="text" class="form-control" id="userInput" placeholder="Enter Email or Mobile No." required style="color: black;">
        </div>

        <button class="btn btn-primary w-100" id="sendOtpBtn">Send OTP</button>

        <!-- OTP Input (Hidden Initially) -->
        <div id="otpSection" class="mt-3" style="display: none;">
            <label for="otpInput" class="form-label">Enter OTP</label>
            <input type="text" class="form-control" id="otpInput" placeholder="Enter OTP">
            <button class="btn btn-danger w-100 mt-2" id="verifyAndDeleteBtn">Verify & Delete</button>
        </div>
    </div>
    <div class="container">
        <h2>User Deletion & OTP Verification</h2>

        <h3>1. OTP Verification Before Deletion</h3>
        <ul>
            <li>A One-Time Password (OTP) is generated and sent via SMS and/or email.</li>
            <li>The user must enter the correct OTP to confirm the deletion request.</li>
            <li>If the OTP is incorrect or expired, the deletion process is denied.</li>
        </ul>

        <h3>2. User Deletion Process</h3>
        <ul>
            <li>Upon successful OTP verification, the system checks for eKYC validation.</li>
            <li>The user’s account is marked as <span class="important">"Deleted"</span>, and all associated data is removed.</li>
            <li>If the user has a <strong>video KYC</strong> file, it is permanently deleted from the server.</li>
        </ul>

        <h3>3. Data Irrecoverability</h3>
        <ul>
            <li class="important">⚠ Once deleted, the user’s data <strong>cannot be recovered.</strong></li>
            <li>The deleted user’s account will no longer be accessible in the system.</li>
            <li>Any services or transactions linked to the user will also be removed.</li>
        </ul>

        <h3>4. Security Measures</h3>
        <ul>
            <li>The system updates the user’s <strong>security stamp</strong> after deletion to prevent unauthorized access.</li>
            <li>The deleted user will be restricted from any actions in the system.</li>
        </ul>

        <h3>5. Logging and Tracking</h3>
        <ul>
            <li>The system maintains logs of deleted users for security and audit purposes.</li>
            <li>Admins receive notifications for user deletions to prevent unauthorized actions.</li>
        </ul>

        <p class="important">🚨 Please proceed with caution, as deleted user data cannot be restored!</p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $("#sendOtpBtn").click(function () {
            console.log("clicked")
            var userInput = $("#userInput").val();
            if (userInput === "") {
                alert("Please enter Email or Mobile No.");
                return;
            }
            $.ajax({
                url: '@Url.Action("DeleteRetailer", "Home")',
                type: "POST",
                data: { mobiles: userInput },
                success: function (response) {
                    if (response == "success") {
                        alert("OTP sent successfully!");
                        $("#otpSection").show();
                    } else {
                        alert(response);
                    }
                }
            });
        });

        $("#verifyAndDeleteBtn").click(function () {
            var otp = $("#otpInput").val();
            var userInput = $("#userInput").val();

            if (otp === "") {
                alert("Please enter OTP.");
                return;
            }
            $.ajax({
                url: '@Url.Action("ConfirmDeleteRetailerOTP", "Home")',
                type: "POST",
                data: { Deleteotp: otp, mobile: userInput },
                success: function (response) {
                    if (response == "success") {
                        alert("User deleted successfully!");
                        location.reload();
                    } else {
                        alert(response);
                    }
                }
            });
        });
    });
</script>

